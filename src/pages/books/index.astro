---
// src/pages/books/index.astro
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';

const books = Object.values(import.meta.glob('./*.md', { eager: true })) as any[];

// Sort books: by date descending if available, else alphabetically by title
const sortedBooks = books.sort((a, b) => {
  const dateA = a.frontmatter.date ? new Date(a.frontmatter.date).getTime() : 0;
  const dateB = b.frontmatter.date ? new Date(b.frontmatter.date).getTime() : 0;
  if (dateA !== dateB) {
    return dateB - dateA;
  }
  return (a.frontmatter.title || "").localeCompare(b.frontmatter.title || "");
});
---

<Layout title="Books" description="Browse Abdurakhmon Dadaboev's book list, featuring curated literature, philosophy, and technical volumes.">
  <div class="books-header">
    <h1 class="page-title" style="margin-bottom: 0.5rem;">Books & Reading</h1>
    <p class="subtitle">Books I read</p>
  </div>

  <div class="books-grid">
    {sortedBooks.map((book) => (
      <a href={`https://www.google.com/search?q=${encodeURIComponent(book.frontmatter.title + ' by ' + book.frontmatter.author)}`} target="_blank" rel="noopener noreferrer" class="book-card-link">
        <div class="book-card">
          <div class="book-cover-wrapper">
            <Image 
              src={book.frontmatter.cover} 
              alt={`Cover of ${book.frontmatter.title}`} 
              width={200}
              height={290}
              class="book-cover"
            />
          </div>
          <h3 class="book-title">{book.frontmatter.title}</h3>
          <p class="book-author">By {book.frontmatter.author}</p>
          {book.frontmatter.description && <p class="book-description">{book.frontmatter.description}</p>}
        </div>
      </a>
    ))}
  </div>

  <style>
    .books-header {
      margin-bottom: clamp(2rem, 5vh, 3.5rem);
      padding-top: 1rem;
    }
    .subtitle {
      font-size: 1.1rem;
      color: var(--text-secondary);
    }
    .books-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: clamp(1.5rem, 4vw, 2.5rem);
      margin-bottom: 4rem;
    }
    .book-card-link {
      text-decoration: none;
      color: inherit;
    }
    .book-card {
      display: flex;
      flex-direction: column;
      height: 100%;
      transition: var(--transition-smooth);
    }
    .book-cover-wrapper {
      position: relative;
      aspect-ratio: 2 / 3;
      border-radius: 8px;
      overflow: hidden;
      box-shadow: var(--shadow-sm);
      border: 1px solid var(--border-color);
      background-color: rgba(90, 96, 72, 0.02);
      margin-bottom: 0.85rem;
      transition: var(--transition-smooth);
    }
    .book-cover {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: var(--transition-smooth);
    }
    .book-card-link:hover .book-cover-wrapper {
      transform: translateY(-0.25rem);
      box-shadow: var(--shadow-md);
      border-color: var(--border-hover);
    }
    .book-card-link:hover .book-cover {
      transform: scale(1.03);
    }
    .book-title {
      font-size: 1.05rem;
      font-weight: 600;
      color: var(--text-primary);
      margin-top: 0;
      margin-bottom: 0.25rem;
      line-height: 1.35;
    }
    .book-author {
      font-size: 0.875rem;
      color: var(--text-secondary);
      margin-bottom: 0;
    }
    .book-description {
      font-size: 0.85rem;
      color: var(--text-muted);
      margin-top: 0.5rem;
      margin-bottom: 0;
      line-height: 1.4;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    @media (max-width: 480px) {
      .books-grid {
        grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
        gap: 1rem;
      }
    }
  </style>
</Layout>
