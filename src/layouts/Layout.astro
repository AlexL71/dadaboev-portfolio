---
// src/layouts/Layout.astro
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  frontmatter?: {
    title: string;
    description?: string;
    date?: string;
  };
}

const { 
  title: explicitTitle, 
  description: explicitDescription,
  frontmatter
} = Astro.props;

const title = explicitTitle || frontmatter?.title || "Abdurakhmon Dadaboev";
const description = explicitDescription || frontmatter?.description || "Abdurakhmon Dadaboev - Personal Portfolio, Resume Host, and Blog";

const pathname = Astro.url.pathname;
const isCurrent = (path: string) => {
  if (path === '/') {
    return pathname === '/' || pathname === '';
  }
  return pathname.startsWith(path);
};
---

